{
  "ConnectionStrings": {
    "OrderTracking": "Server=localhost;Database=OrderTracking;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "OrderTracking.API",
    "Audience": "OrderTracking.UI",
    "SigningKey": ""
  },
  "Redis": {
    "Enabled": false,
    "Configuration": "localhost:6379"
  },
  "RabbitMQ": {
    "Enabled": false,
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "ExchangeName": "order-tracking.events"
  },
  "DriverMovementSimulator": {
    "Enabled": false,
    "IntervalSeconds": 5,
    "BatchSize": 100,
    "MaxDeltaDegrees": 0.0007
  },
  "OpenTelemetry": {
    "ServiceName": "order-tracking-api"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.RenderedCompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
