{
  "ConnectionStrings": {
    "OrderTracking": "Server=localhost;Database=OrderTracking;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "OrderTracking.API",
    "Audience": "OrderTracking.UI",
    "SigningKey": "development-only-signing-key-32-characters-minimum"
  },
  "Redis": {
    "Enabled": false
  },
  "RabbitMQ": {
    "Enabled": false
  },
  "DriverMovementSimulator": {
    "Enabled": true,
    "IntervalSeconds": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
